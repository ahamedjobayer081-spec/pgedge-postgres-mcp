# pgEdge Postgres MCP - Docker Compose Configuration
# Copy this file to .env and customize for your environment

# ============================================================================
# SERVICE PORTS
# ============================================================================
# Port for MCP server HTTP endpoint
MCP_SERVER_PORT=8080

# Port for web client
WEB_CLIENT_PORT=8081

# ============================================================================
# DATABASE CONNECTION (Single Database)
# ============================================================================
# PostgreSQL connection details for a single database.
# For multiple databases, see the MULTIPLE DATABASES section below.
PGEDGE_DB_HOST=your-postgres-host
PGEDGE_DB_PORT=5432
PGEDGE_DB_NAME=your-database-name
PGEDGE_DB_USER=your-database-user
PGEDGE_DB_PASSWORD=your-database-password
PGEDGE_DB_SSLMODE=prefer

# ============================================================================
# MULTIPLE DATABASES (Optional)
# ============================================================================
# To configure multiple databases, use numbered environment variables.
# The server will automatically generate a config file when these are set.
# Supports up to 99 databases (PGEDGE_DB_1_* through PGEDGE_DB_99_*).
# Numbers don't need to be sequential; gaps are skipped automatically.
#
# Each database requires at minimum a NAME or HOST. Other fields have defaults:
#   - PORT: 5432
#   - DATABASE: same as NAME
#   - USER: postgres
#   - PASSWORD: (empty)
#   - SSLMODE: prefer
#   - ALLOW_WRITES: false
#
# Example: Two databases (production read-only, development with writes)
# PGEDGE_DB_1_NAME=production
# PGEDGE_DB_1_HOST=prod-db.example.com
# PGEDGE_DB_1_PORT=5432
# PGEDGE_DB_1_DATABASE=prod_db
# PGEDGE_DB_1_USER=readonly_user
# PGEDGE_DB_1_PASSWORD=secret123
# PGEDGE_DB_1_SSLMODE=require
# PGEDGE_DB_1_ALLOW_WRITES=false
#
# PGEDGE_DB_2_NAME=development
# PGEDGE_DB_2_HOST=localhost
# PGEDGE_DB_2_PORT=5432
# PGEDGE_DB_2_DATABASE=dev_db
# PGEDGE_DB_2_USER=postgres
# PGEDGE_DB_2_PASSWORD=devpass
# PGEDGE_DB_2_SSLMODE=disable
# PGEDGE_DB_2_ALLOW_WRITES=true

# Enable LLM database switching (only applies when multiple databases are configured)
# When enabled, the LLM can use tools to list and switch between databases.
# When disabled (default), users can still switch databases manually via CLI/Web UI.
# Values: true, false (default: false)
# PGEDGE_LLM_DB_SWITCHING=false

# ============================================================================
# EMBEDDING PROVIDER CONFIGURATION
# ============================================================================
# Enable embedding generation tools (for vector similarity search)
# PGEDGE_EMBEDDING_ENABLED=true

# Provider for text embeddings: anthropic, openai, or ollama
PGEDGE_EMBEDDING_PROVIDER=anthropic

# Model to use for embeddings
# Anthropic: voyage-3, voyage-3-large (requires API key)
# OpenAI: text-embedding-3-small, text-embedding-3-large (requires API key)
# Ollama: nomic-embed-text, mxbai-embed-large (requires local Ollama)
PGEDGE_EMBEDDING_MODEL=voyage-3

# ============================================================================
# LLM API KEYS
# ============================================================================
# Anthropic API key (for Claude models and Voyage embeddings)
# Get your key from: https://console.anthropic.com/
PGEDGE_ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API key (for GPT models and OpenAI embeddings)
# Get your key from: https://platform.openai.com/
PGEDGE_OPENAI_API_KEY=your-openai-api-key-here

# Ollama server URL (for local models)
# Default: http://localhost:11434 (change if Ollama runs elsewhere)
PGEDGE_OLLAMA_URL=http://localhost:11434

# ============================================================================
# CUSTOM BASE URLs (for proxies or self-hosted endpoints)
# ============================================================================
# Override default API endpoints for use with proxies or compatible services.
# Leave empty to use default endpoints.

# Anthropic API base URL (default: https://api.anthropic.com)
# PGEDGE_ANTHROPIC_BASE_URL=

# OpenAI API base URL (default: https://api.openai.com)
# PGEDGE_OPENAI_BASE_URL=

# Voyage AI API base URL (default: https://api.voyageai.com/v1/embeddings)
# PGEDGE_VOYAGE_BASE_URL=

# OpenAI embeddings base URL (if different from main OpenAI URL)
# PGEDGE_OPENAI_EMBEDDING_BASE_URL=

# ============================================================================
# AUTHENTICATION CONFIGURATION
# ============================================================================
# The server supports both token-based and user-based authentication
# simultaneously. You can initialize both types during container startup.

# Initialize tokens (comma-separated list)
# Use for service-to-service authentication or API access
# Format: token1,token2,token3
# Example: INIT_TOKENS=my-secret-token-1,my-secret-token-2
INIT_TOKENS=

# Initialize users (comma-separated list of username:password pairs)
# Use for interactive user authentication with session tokens
# Format: username1:password1,username2:password2
# Example: INIT_USERS=alice:secret123,bob:secret456
INIT_USERS=

# Client token for CLI access (if using token authentication)
# This should match one of the tokens in INIT_TOKENS
MCP_CLIENT_TOKEN=

# ============================================================================
# RATE LIMITING (Optional)
# ============================================================================
# Protect against brute-force attacks on authentication endpoints.

# Lock account after N failed login attempts (0 = disabled)
# PGEDGE_AUTH_MAX_FAILED_ATTEMPTS_BEFORE_LOCKOUT=0

# Time window for rate limiting (minutes)
# PGEDGE_AUTH_RATE_LIMIT_WINDOW_MINUTES=15

# Maximum failed attempts per IP within window
# PGEDGE_AUTH_RATE_LIMIT_MAX_ATTEMPTS=10

# ============================================================================
# LLM CONFIGURATION FOR CLIENTS
# ============================================================================
# Enable LLM proxy for web clients (allows chat functionality)
PGEDGE_LLM_ENABLED=true

# Default LLM provider for chat clients: anthropic, openai, or ollama
PGEDGE_LLM_PROVIDER=anthropic

# Default LLM model for chat clients
# Anthropic: claude-sonnet-4-20250514, claude-opus-4-20250514, etc.
# OpenAI: gpt-5-main, gpt-4o, gpt-4-turbo, etc.
# Ollama: llama3, mistral, etc.
PGEDGE_LLM_MODEL=claude-sonnet-4-20250514

# Maximum tokens in LLM response (default: 4096)
# PGEDGE_LLM_MAX_TOKENS=4096

# Temperature for LLM responses (0.0-1.0, default: 0.7)
# Lower values = more deterministic, higher = more creative
# PGEDGE_LLM_TEMPERATURE=0.7

# ============================================================================
# KNOWLEDGEBASE CONFIGURATION (Optional)
# ============================================================================
# Enable semantic search over custom documentation. Requires a pre-built
# knowledgebase database (SQLite file with embeddings).

# Enable knowledgebase search tools
# PGEDGE_KB_ENABLED=false

# Path to knowledgebase database file
# PGEDGE_KB_DATABASE_PATH=

# Embedding provider for knowledgebase (voyage, openai, or ollama)
# PGEDGE_KB_EMBEDDING_PROVIDER=

# Embedding model for knowledgebase
# PGEDGE_KB_EMBEDDING_MODEL=

# Knowledgebase-specific API keys (if different from main keys)
# PGEDGE_KB_VOYAGE_API_KEY=
# PGEDGE_KB_OPENAI_API_KEY=
# PGEDGE_KB_OLLAMA_URL=

# Knowledgebase-specific base URLs (for proxies)
# PGEDGE_KB_VOYAGE_BASE_URL=
# PGEDGE_KB_OPENAI_BASE_URL=

# ============================================================================
# DEBUGGING AND LOGGING
# ============================================================================
# Enable debug mode for server
PGEDGE_DEBUG=false

# Database operation logging: none, info, debug, trace
PGEDGE_DB_LOG_LEVEL=none

# LLM/Embedding operation logging: none, info, debug, trace
PGEDGE_LLM_LOG_LEVEL=none

# Disable colored output for CLI client
NO_COLOR=

# ============================================================================
# EXAMPLE CONFIGURATIONS
# ============================================================================

# Example 1: Stdio mode with Anthropic (development)
# Not applicable for Docker - Docker uses HTTP mode

# Example 2: HTTP mode with Anthropic Claude (production)
# MCP_SERVER_PORT=8080
# WEB_CLIENT_PORT=8081
# PGEDGE_DB_HOST=postgres.example.com
# PGEDGE_DB_PORT=5432
# PGEDGE_DB_NAME=myapp
# PGEDGE_DB_USER=postgres
# PGEDGE_DB_PASSWORD=secure_password
# PGEDGE_EMBEDDING_PROVIDER=anthropic
# PGEDGE_EMBEDDING_MODEL=voyage-3
# PGEDGE_ANTHROPIC_API_KEY=sk-ant-api03-...
# INIT_TOKENS=production-token-1,production-token-2
# PGEDGE_LLM_PROVIDER=anthropic
# PGEDGE_LLM_MODEL=claude-sonnet-4-20250514

# Example 3: With OpenAI
# PGEDGE_EMBEDDING_PROVIDER=openai
# PGEDGE_EMBEDDING_MODEL=text-embedding-3-small
# PGEDGE_OPENAI_API_KEY=sk-proj-...
# PGEDGE_LLM_PROVIDER=openai
# PGEDGE_LLM_MODEL=gpt-4o

# Example 4: With local Ollama
# PGEDGE_EMBEDDING_PROVIDER=ollama
# PGEDGE_EMBEDDING_MODEL=nomic-embed-text
# PGEDGE_OLLAMA_URL=http://host.docker.internal:11434
# PGEDGE_LLM_PROVIDER=ollama
# PGEDGE_LLM_MODEL=llama3

# Example 5: With user authentication
# INIT_USERS=alice:password123,bob:password456

# Example 6: With both tokens and users
# INIT_TOKENS=api-token-1,api-token-2
# INIT_USERS=alice:password123,bob:password456

# Example 7: Multiple databases
# Configure multiple databases for different environments.
# Users can switch between databases at runtime.
# PGEDGE_DB_1_NAME=production
# PGEDGE_DB_1_HOST=prod-db.example.com
# PGEDGE_DB_1_DATABASE=prod_db
# PGEDGE_DB_1_USER=readonly_user
# PGEDGE_DB_1_PASSWORD=secret123
# PGEDGE_DB_1_SSLMODE=require
# PGEDGE_DB_1_ALLOW_WRITES=false
#
# PGEDGE_DB_2_NAME=staging
# PGEDGE_DB_2_HOST=staging-db.example.com
# PGEDGE_DB_2_DATABASE=staging_db
# PGEDGE_DB_2_USER=developer
# PGEDGE_DB_2_PASSWORD=staging456
# PGEDGE_DB_2_SSLMODE=prefer
# PGEDGE_DB_2_ALLOW_WRITES=false
#
# PGEDGE_DB_3_NAME=development
# PGEDGE_DB_3_HOST=localhost
# PGEDGE_DB_3_DATABASE=dev_db
# PGEDGE_DB_3_USER=postgres
# PGEDGE_DB_3_PASSWORD=devpass
# PGEDGE_DB_3_SSLMODE=disable
# PGEDGE_DB_3_ALLOW_WRITES=true
