# pgEdge Postgres MCP - Docker Compose Configuration
# Copy this file to .env and customize for your environment
#
# For advanced configuration options (multiple databases, knowledgebase,
# rate limiting, custom API endpoints), see docs/guide/env_variable_config.md

# ============================================================================
# HTTP MODE (required for Docker Compose deployments with web client)
# ============================================================================
# Set to "true" to enable HTTP transport; omit for stdio mode
PGEDGE_HTTP_ENABLED=true

# ============================================================================
# SERVICE PORTS
# ============================================================================
MCP_SERVER_PORT=8080
WEB_CLIENT_PORT=8081

# ============================================================================
# DATABASE CONNECTION
# ============================================================================
PGEDGE_DB_HOST=your-postgres-host
PGEDGE_DB_PORT=5432
PGEDGE_DB_NAME=your-database-name
PGEDGE_DB_USER=your-database-user
PGEDGE_DB_PASSWORD=your-database-password
PGEDGE_DB_SSLMODE=prefer

# Allow write queries (INSERT, UPDATE, DELETE, etc.) - default: false
# WARNING: Use with caution. See docs/guide/security.md for details.
# PGEDGE_DB_ALLOW_WRITES=false

# ============================================================================
# EMBEDDING CONFIGURATION
# ============================================================================
# Provider: anthropic, openai, or ollama
PGEDGE_EMBEDDING_PROVIDER=anthropic
PGEDGE_EMBEDDING_MODEL=voyage-3

# ============================================================================
# API KEYS
# ============================================================================
# Anthropic: https://console.anthropic.com/
PGEDGE_ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI: https://platform.openai.com/
PGEDGE_OPENAI_API_KEY=your-openai-api-key-here

# Ollama (for local models)
PGEDGE_OLLAMA_URL=http://localhost:11434

# ============================================================================
# AUTHENTICATION
# ============================================================================
# Initialize users (username:password pairs, comma-separated)
# Example: INIT_USERS=alice:secret123,bob:secret456
INIT_USERS=

# Initialize API tokens (comma-separated)
# Example: INIT_TOKENS=my-token-1,my-token-2
INIT_TOKENS=

# ============================================================================
# LLM CONFIGURATION
# ============================================================================
# Provider: anthropic, openai, or ollama
PGEDGE_LLM_PROVIDER=anthropic
PGEDGE_LLM_MODEL=claude-sonnet-4-20250514

# ============================================================================
# DEBUGGING
# ============================================================================
PGEDGE_DEBUG=false
